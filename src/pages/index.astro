---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section>
    <h1>Welcome to My Blog</h1>
    <p>
      Hello there! I'm Alok, and this is my personal blog where I share insights
      on technology, coding, and web development. Dive in to explore tutorials,
      tips, and the latest trends in the industry.
    </p>
  </section>
  <section>
    <h2>Stay Connected</h2>
    <p>
      Don't miss out on the latest updates and posts. <a href="/subscribe"
        >Subscribe to my newsletter</a
      >
    </p>
  </section>
  <section>
    <h2>Search</h2>
    <form action="/search" method="get">
      <input type="text" name="q" placeholder="Search the blog..." />
      <button type="submit">Search</button>
    </form>
  </section>
</BaseLayout>
